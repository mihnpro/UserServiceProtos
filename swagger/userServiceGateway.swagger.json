          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "userServiceExperienceLevel": {
      "type": "string",
      "enum": [
        "EXPERIENCE_LEVEL_UNSPECIFIED",
        "EXPERIENCE_LEVEL_BEGINNER",
        "EXPERIENCE_LEVEL_INTERMEDIATE",
        "EXPERIENCE_LEVEL_ADVANCED",
        "EXPERIENCE_LEVEL_PROFESSIONAL"
      ],
      "default": "EXPERIENCE_LEVEL_UNSPECIFIED",
      "description": "- EXPERIENCE_LEVEL_UNSPECIFIED: Уровень не указан\n - EXPERIENCE_LEVEL_BEGINNER: Начинающий\n - EXPERIENCE_LEVEL_INTERMEDIATE: Средний уровень\n - EXPERIENCE_LEVEL_ADVANCED: Продвинутый\n - EXPERIENCE_LEVEL_PROFESSIONAL: Профессиональный",
      "title": "Уровень опыта пользователя в фитнесе"
    },
    "userServiceFitnessGoal": {
      "type": "string",
      "enum": [
        "FITNESS_GOAL_UNSPECIFIED",
        "FITNESS_GOAL_WEIGHT_LOSS",
        "FITNESS_GOAL_MUSCLE_GAIN",
        "FITNESS_GOAL_ENDURANCE",
        "FITNESS_GOAL_GENERAL_HEALTH",
        "FITNESS_GOAL_MAINTENANCE"
      ],
      "default": "FITNESS_GOAL_UNSPECIFIED",
      "description": "- FITNESS_GOAL_UNSPECIFIED: Цель не указана\n - FITNESS_GOAL_WEIGHT_LOSS: Похудение\n - FITNESS_GOAL_MUSCLE_GAIN: Набор мышечной массы\n - FITNESS_GOAL_ENDURANCE: Развитие выносливости\n - FITNESS_GOAL_GENERAL_HEALTH: Общее оздоровление\n - FITNESS_GOAL_MAINTENANCE: Поддержание формы",
      "title": "Фитнес цель пользователя"
    },
    "userServiceGender": {
